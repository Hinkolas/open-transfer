# Postgres — metadata and transfer logic
# Behind a transaction-mode pooler (pgbouncer etc.), postgres.js needs prepare=false;
# see README.
DATABASE_URL="postgres://user:password@localhost:5432/open_transfer"

# S3-compatible object storage — the files themselves
# Leave S3_ENDPOINT empty for AWS S3; set it for MinIO, Garage, Ceph, etc.
S3_ENDPOINT="https://s3.example.com"
S3_REGION="us-east-1"
S3_BUCKET="open-transfer"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# "true" for most self-hosted S3 providers (path-style addressing)
S3_FORCE_PATH_STYLE="true"

# Public URL of the app — required in production (adapter-node uses it for
# absolute URLs and cross-origin checks). Not needed for `bun run dev`.
ORIGIN="http://localhost:5173"
